# Founder hosted development runtime.
#
# Secret path values must be absolute host paths outside this repository.
# Create these files locally and never commit them.

FOUNDER_API_PORT=8000
FOUNDER_WEB_PORT=3000
FOUNDER_SHARED_DATA_DIR=/var/lib/founder/shared-data
FOUNDER_POSTGRES_PASSWORD_FILE=/run/host-secrets/founder/postgres-password.txt
FOUNDER_SESSION_SECRET_FILE=/run/host-secrets/founder/session-secret.txt
FOUNDER_EODHD_KEK_FILE=/run/host-secrets/founder/eodhd-kek.txt
FOUNDER_GOOGLE_CLIENT_SECRET_FILE=/run/host-secrets/founder/google-client-secret.txt
