# Camovar hosted development runtime.
#
# Secret path values must be absolute host paths outside this repository.
# Create these files locally and never commit them.

CAMOVAR_API_PORT=8000
CAMOVAR_WEB_PORT=3000
CAMOVAR_SHARED_DATA_DIR=/var/lib/camovar/shared-data
CAMOVAR_LAKE_GROUP_ID=10
CAMOVAR_POSTGRES_PASSWORD_FILE=/run/host-secrets/camovar/postgres-password.txt
CAMOVAR_SESSION_SECRET_FILE=/run/host-secrets/camovar/session-secret.txt
CAMOVAR_EODHD_KEK_FILE=/run/host-secrets/camovar/eodhd-kek.txt
CAMOVAR_GOOGLE_CLIENT_SECRET_FILE=/run/host-secrets/camovar/google-client-secret.txt
CAMOVAR_AUTH_MODE=google
CAMOVAR_GOOGLE_CLIENT_ID=
CAMOVAR_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
CAMOVAR_GOOGLE_ALLOWED_DOMAIN=
CAMOVAR_LOCAL_DEV_GOOGLE_EMAIL=local-google-dev-user@example.test
